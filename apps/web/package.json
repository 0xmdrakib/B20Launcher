{
  "name": "@base-b20/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "prebuild": "pnpm --filter @base-b20/b20 build && pnpm --filter @base-b20/api build",
    "build": "next build",
    "pretypecheck": "pnpm --filter @base-b20/b20 build && pnpm --filter @base-b20/api build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@base-b20/api": "workspace:*",
    "@base-b20/b20": "workspace:*",
    "@fontsource-variable/eb-garamond": "^5.3.0",
    "@fontsource-variable/inter": "^5.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@walletconnect/ethereum-provider": "^2.23.10",
    "@x402/core": "^2.19.0",
    "@x402/evm": "^2.19.0",
    "@x402/extensions": "^2.19.0",
    "@x402/next": "^2.19.0",
    "@x402/svm": "^2.19.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.555.0",
    "next": "^16.2.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "viem": "^2.55.4",
    "wagmi": "^3.7.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
